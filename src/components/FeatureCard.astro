---
interface Props {
  titolo: string;
  descrizione: string;
  emoji?: string;
  accent?: "primary" | "secondary";
}
const { titolo, descrizione, emoji = "🍋", accent = "primary" } = Astro.props;
const accentClass = accent === "secondary" ? "bg-secondary text-white" : "bg-primary text-ink";
---

<article class="border-3 border-ink shadow-[6px_6px_0px_#000] bg-surface p-6 flex flex-col gap-4">
  <div class={`inline-flex items-center justify-center w-14 h-14 border-2 border-ink text-3xl shadow-[3px_3px_0px_#000] ${accentClass}`}>
    {emoji}
  </div>

  <h2 class="font-sans font-black text-2xl uppercase text-ink leading-tight">
    {titolo}
  </h2>

  <p class="font-sans text-base text-text leading-relaxed">
    {descrizione}
  </p>
</article>
